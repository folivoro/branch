{
    "name": "folivoro/branch",
    "description": "Local package development for Composer without modifying composer.json",
    "type": "composer-plugin",
    "license": "MIT",
    "keywords": [
        "composer",
        "plugin",
        "local",
        "development",
        "path-repository"
    ],
    "require": {
        "php": ">=8.1",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Folivoro\\Branch\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Folivoro\\Branch\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "folivoro/branch": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "class": "Folivoro\\Branch\\BranchPlugin"
    }
}
